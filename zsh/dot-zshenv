export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_STATE_HOME="$HOME/.local/state"

export EDITOR=nvim

# set up Homebrew for multi-admin access through brewer user
export HOMEBREW_CACHE="/opt/homebrew/cache"
export HOMEBREW_LOGS="/opt/homebrew/logs"
export HOMEBREW_CASK_OPTS="--fontdir=/Library/Fonts"
# export HOMEBREW_NO_ENV_HINTS=true

# set up FNM for multi-user access
export FNM_DIR="/Library/Application Support/fnm"

export GOKU_EDN_CONFIG_FILE=$XDG_CONFIG_HOME/karabiner/karabiner.edn

# Use terminal ANSI colors for CLI tools (inherits from WezTerm theme)
export FZF_DEFAULT_OPTS="--color=16"
export BAT_THEME="ansi"

# vim:syntax=sh
