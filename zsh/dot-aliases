claude() {
  if (( $+commands[jq] )); then
    local mode="light"
    defaults read -g AppleInterfaceStyle &>/dev/null && mode="dark"

    local cfg=~/.claude.json
    local current=$(jq -r '.theme // ""' "$cfg" 2>/dev/null)
    if [[ "$current" != "$mode" ]]; then
      jq --arg t "$mode" '.theme = $t' "$cfg" > "${cfg}.tmp" && mv "${cfg}.tmp" "$cfg"
    fi
  fi

  command claude "$@"
}

heic_to_jpg() {
  extension=${2##*.}
  echo $extension
  if [[ $extension != 'jpg' && $extension != 'jpeg' ]]; then
    echo "Error: extension must be 'jpg' or 'jpeg'"
  else
    sips -s format jpeg $1 --out $2
  fi
}

mov2mp4() {
    local filters=''
    local args=(-i "$1" -c:v libx264 -preset medium -crf 23 -c:a aac -b:a 192k -map_metadata -1 -movflags +faststart -async 1)
    if [[ "$2" == "-f" ]]; then
        local speedup_factor=$3
        local scale=$(bc <<< "scale=2; 1/$speedup_factor")
        filters='[0:v]setpts='"$scale"'*PTS[v];[0:a]atempo='"$speedup_factor"'[a]'
    fi
    if [[ -n "$filters" ]]; then
        args+=(-filter_complex "$filters" -map "[v]" -map "[a]")
    fi
    ffmpeg "${args[@]}" "${1:r}.mp4"
}

